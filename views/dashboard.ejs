<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard – AnsuMart</title>
  <link rel="stylesheet" href="/css/dashboard.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
</head>
<body>

<!-- NAVBAR -->
<header class="navbar">
  <a href="/" class="brand">🛒 <span>AnsuMart</span></a>
  <nav class="nav-tabs">
    <button class="tab active" data-tab="overview"><i class="fa-solid fa-border-all"></i> Overview</button>
    <button class="tab" data-tab="orders"><i class="fa-solid fa-box-open"></i> My Orders</button>
    <button class="tab" data-tab="wishlist"><i class="fa-solid fa-heart"></i> Wishlist</button>
    <button class="tab" data-tab="location"><i class="fa-solid fa-location-dot"></i> Location</button>
    <button class="tab" data-tab="profile"><i class="fa-solid fa-user-pen"></i> My Details</button>
  </nav>
  <a href="/logout" class="btn-logout"><i class="fa fa-right-from-bracket"></i> Logout</a>
</header>

<div class="page">

  <!-- ======== OVERVIEW ======== -->
  <section id="overview" class="tab-section active">

    <div class="welcome-bar">
      <div>
        <h1>Hey, <%= user.firstName %> 👋</h1>
        <p>Welcome back to AnsuMart</p>
      </div>
      <a href="/store" class="btn-green"><i class="fa fa-bag-shopping"></i> Shop Now</a>
    </div>

    <div class="cards-row">
      <div class="info-card" onclick="switchTab('orders')">
        <div class="card-icon green"><i class="fa fa-box-open"></i></div>
       <span class="card-num"><%= totalOrders %></span>
        <span class="card-label">Total Orders</span>
      </div>
      <div class="info-card" onclick="switchTab('wishlist')">
        <div class="card-icon red"><i class="fa fa-heart"></i></div>
        <span class="card-num"><%= wishlistCount %></span>
        <span class="card-label">Wishlist</span>
      </div>
      <div class="info-card" onclick="switchTab('location')">
        <div class="card-icon orange"><i class="fa fa-location-dot"></i></div>
        <span class="card-num"><%= user.address && user.address.city ? user.address.city : '—' %></span>
        <span class="card-label">Delivery City</span>
      </div>
    </div>

  </section>

  <!-- ======== MY ORDERS ======== -->
  <section id="orders" class="tab-section">
    <h2 class="section-title"><i class="fa fa-box"></i> My Orders</h2>

    <% if (orders && orders.length > 0) { %>
      <div class="orders-list">
        <% orders.forEach(order => {
          const statusSteps = ['pending','confirmed','dispatched','out_for_delivery','delivered'];
          const statusLabels = {
            pending:          { label: 'Order Placed',       icon: 'fa-clock',            color: '#f59e0b' },
            confirmed:        { label: 'Confirmed',          icon: 'fa-circle-check',     color: '#3b82f6' },
            dispatched:       { label: 'Dispatched',         icon: 'fa-box',              color: '#8b5cf6' },
            out_for_delivery: { label: 'Out for Delivery',   icon: 'fa-truck-fast',       color: '#f97316' },
            delivered:        { label: 'Delivered',          icon: 'fa-house-circle-check',color: '#22c55e' },
            cancelled:        { label: 'Cancelled',          icon: 'fa-circle-xmark',     color: '#ef4444' },
          };
          const curStatus = order.status || 'pending';
          const curStepIdx = statusSteps.indexOf(curStatus);
          const isCancelled = curStatus === 'cancelled';
        %>
        <div class="order-card">
          <!-- Order Header -->
          <div class="order-top">
            <div>
              <span class="order-id">Order #<%= order._id.toString().slice(-8).toUpperCase() %></span>
              <span class="order-date"><i class="fa fa-calendar-alt"></i> <%= new Date(order.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></span>
            </div>
            <span class="status-badge <%= curStatus %>">
              <i class="fa <%= (statusLabels[curStatus]||{}).icon || 'fa-circle' %>"></i>
              <%= (statusLabels[curStatus]||{}).label || curStatus %>
            </span>
          </div>

          <!-- Delivery Timeline -->
          <% if (!isCancelled) { %>
          <div class="timeline">
            <% statusSteps.forEach((step, i) => {
              const done = i <= curStepIdx;
              const active = i === curStepIdx;
              const sl = statusLabels[step];
            %>
            <div class="tl-step <%= done ? 'done' : '' %> <%= active ? 'active' : '' %>">
              <div class="tl-dot" style="<%= done ? 'background:'+sl.color+';border-color:'+sl.color : '' %>">
                <i class="fa <%= done ? sl.icon : 'fa-circle' %>" style="color:<%= done ? '#fff' : '#cbd5e1' %>;font-size:0.65rem;"></i>
              </div>
              <span class="tl-label"><%= sl.label %></span>
            </div>
            <% if (i < statusSteps.length-1) { %>
            <div class="tl-line <%= done && i < curStepIdx ? 'done' : '' %>"></div>
            <% } %>
            <% }) %>
          </div>
          <% } %>

          <!-- Items -->
          <div class="order-items-grid">
            <% order.items.forEach(item => {
              const imgSrc = item.image || '';
            %>
            <div class="oi-chip">
              <% if (imgSrc) { %>
              <img class="oi-img" src="<%= imgSrc %>" alt="<%= item.name %>"
                   onerror="this.style.display='none'"/>
              <% } %>
              <div class="oi-info">
                <span class="oi-name"><%= item.name %></span>
                <span class="oi-qty">Qty: <%= item.quantity %> &middot; ₹<%= item.price %> each</span>
              </div>
            </div>
            <% }) %>
          </div>

          <!-- Footer -->
          <div class="order-footer">
            <div class="order-addr">
              <i class="fa fa-location-dot"></i>
              <span>
                <% if (order.deliveryAddress && order.deliveryAddress.line) { %>
                  <%= order.deliveryAddress.line %>, <%= order.deliveryAddress.city %> – <%= order.deliveryAddress.pincode %>
                <% } else { %>Address not saved<% } %>
              </span>
            </div>
            <div class="order-total">
              <span class="pay-tag"><i class="fa fa-money-bill-wave"></i> COD</span>
              <strong class="order-amount">₹<%= order.totalAmount %></strong>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty">
        <i class="fa fa-box-open"></i>
        <p>No orders yet. <a href="/shop">Start shopping!</a></p>
      </div>
    <% } %>
  </section>

  <!-- ======== WISHLIST ======== -->
  <section id="wishlist" class="tab-section">
    <h2 class="section-title"><i class="fa fa-heart"></i> My Wishlist <span style="font-size:14px;font-weight:500;color:#94a3b8;margin-left:6px;">(<%= wishlistCount %> items)</span></h2>

    <% if (wishlist && wishlist.length > 0) { %>
      <div class="wish-grid">
        <% wishlist.forEach(function(p) {
          const img = (p.images && p.images.length) ? p.images[0] : (p.image || '');
        %>
        <div class="wish-card" id="wc-<%= p._id %>">
          <a href="/product/<%= p._id %>" style="text-decoration:none;display:block;">
            <% if (img) { %>
              <img src="<%= img %>" alt="<%= p.title %>" onerror="this.style.display='none'"/>
            <% } else { %>
              <div style="width:100%;height:110px;display:flex;align-items:center;justify-content:center;font-size:36px;background:#f1f5f9;border-radius:10px;">📦</div>
            <% } %>
            <p class="wish-name"><%= p.title %></p>
            <p class="wish-price">₹<%= p.price %></p>
          </a>
          <div class="wish-btns">
            <a href="/product/<%= p._id %>" class="btn-sm green">
              <i class="fa fa-eye"></i> View
            </a>
            <button class="btn-sm red" onclick="removeWishlist('<%= p._id %>', this)">
              <i class="fa fa-heart-crack"></i> Remove
            </button>
          </div>
        </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty">
        <i class="fa fa-heart" style="font-size:40px;color:#fca5a5;"></i>
        <p>Nothing saved yet. <a href="/shop">Browse products!</a></p>
      </div>
    <% } %>
  </section>

  <!-- ======== LOCATION ======== -->
  <section id="location" class="tab-section">
    <h2 class="section-title"><i class="fa fa-location-dot"></i> Delivery Location</h2>

    <form class="simple-form" action="/dashboard/location" method="POST">

      <button type="button" class="btn-gps" id="gpsBtn" onclick="fetchGPS()">
        <i class="fa fa-crosshairs"></i>
        <span id="gpsTxt">Use My Current Location</span>
      </button>
      <p class="gps-status" id="gpsStatus"></p>

      <div class="form-group">
        <label>House / Street</label>
        <input type="text" name="line" id="fLine"
               value="<%= user.address && user.address.line ? user.address.line : '' %>"
               placeholder="House No., Street, Area"/>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>City</label>
          <input type="text" name="city" id="fCity"
                 value="<%= user.address && user.address.city ? user.address.city : '' %>"
                 placeholder="City"/>
        </div>
        <div class="form-group">
          <label>State</label>
          <input type="text" name="state" id="fState"
                 value="<%= user.address && user.address.state ? user.address.state : '' %>"
                 placeholder="State"/>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Pincode</label>
          <input type="text" name="pincode" id="fPincode"
                 value="<%= user.address && user.address.pincode ? user.address.pincode : '' %>"
                 placeholder="Pincode"/>
        </div>
        <div class="form-group">
          <label>Type</label>
          <select name="addressType">
            <option value="home"  <%= user.address && user.address.type==='home'  ? 'selected':'' %>>🏠 Home</option>
            <option value="work"  <%= user.address && user.address.type==='work'  ? 'selected':'' %>>🏢 Work</option>
            <option value="other" <%= user.address && user.address.type==='other' ? 'selected':'' %>>📍 Other</option>
          </select>
        </div>
      </div>

      <input type="hidden" name="latitude"  id="fLat"/>
      <input type="hidden" name="longitude" id="fLng"/>

      <button type="submit" class="btn-green full">
        <i class="fa fa-floppy-disk"></i> Save Location
      </button>

      <% if (typeof locMsg !== 'undefined' && locMsg) { %>
        <p class="msg success"><i class="fa fa-circle-check"></i> <%= locMsg %></p>
      <% } %>
    </form>
  </section>

  <!-- ======== MY DETAILS ======== -->
  <section id="profile" class="tab-section">
    <h2 class="section-title"><i class="fa fa-user"></i> My Details</h2>

    <form class="simple-form" action="/dashboard/profile" method="POST">

      <div class="form-row">
        <div class="form-group">
          <label>First Name</label>
          <input type="text" name="firstName" value="<%= user.firstName %>" required/>
        </div>
        <div class="form-group">
          <label>Last Name</label>
          <input type="text" name="lastName" value="<%= user.lastName %>" required/>
        </div>
      </div>

      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" value="<%= user.email %>" required/>
      </div>

      <div class="form-group">
        <label>Phone</label>
        <input type="tel" name="phone" value="<%= user.phone || '' %>" placeholder="+91 98765 43210"/>
      </div>

      <hr class="divider"/>
      <p class="pw-hint">Change Password <span>(leave blank to keep current password)</span></p>

      <div class="form-group">
        <label>New Password</label>
        <div class="pw-wrap">
          <input type="password" name="newPassword" id="newPw" placeholder="Min 8 characters"/>
          <button type="button" class="eye-btn" onclick="togglePw('newPw',this)"><i class="fa fa-eye"></i></button>
        </div>
      </div>

      <div class="form-group">
        <label>Confirm Password</label>
        <div class="pw-wrap">
          <input type="password" name="confirmPassword" id="confPw" placeholder="Repeat password"/>
          <button type="button" class="eye-btn" onclick="togglePw('confPw',this)"><i class="fa fa-eye"></i></button>
        </div>
      </div>

      <button type="submit" class="btn-green full">
        <i class="fa fa-floppy-disk"></i> Save Changes
      </button>

      <% if (typeof profileMsg !== 'undefined' && profileMsg) { %>
        <p class="msg success"><i class="fa fa-circle-check"></i> <%= profileMsg %></p>
      <% } %>
      <% if (typeof profileErr !== 'undefined' && profileErr) { %>
        <p class="msg error"><i class="fa fa-circle-exclamation"></i> <%= profileErr %></p>
      <% } %>
    </form>
  </section>

</div><!-- /page -->





<% if(typeof user !== 'undefined' && user) { %>
<!-- ═══════ BOTTOM NAV (MOBILE) ═══════ -->
<nav class="bottom-nav">
  <a href="/store" class="bnav-item ">
    <i class="fa-solid fa-house"></i>
    <span>Home</span>
  </a>
  <a href="/shop" class="bnav-item ">
    <i class="fa-solid fa-bag-shopping"></i>
    <span>Shop</span>
  </a>
  <a href="/cart" class="bnav-item ">
    <i class="fa-solid fa-cart-shopping"></i>
    <span>Cart</span>
  </a>
  <a href="/profile" class="bnav-item active">
    <i class="fa-solid fa-user"></i>
    <span>Profile</span>
  </a>
</nav>
<% } %>

<div id="toast" class="toast"></div>
<script src="/js/dashboard.js"></script>
</body>
</html>

