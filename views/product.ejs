<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= product.title %> – AnsuMart
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/product.css" />

  <!-- PWA Meta Tags -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#2d8a4e" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="AnsuMart" />
  <link rel="apple-touch-icon" href="/image/icon-192.png" />
</head>

<body>

  <% const _mins=typeof deliveryMins !=='undefined' ? Number(deliveryMins) : 30; const _delText=_mins> 100 ?
    (_mins/60).toFixed(1) + ' hrs' : _mins + ' mins';
    const _delLoc = typeof deliveryLocation !== 'undefined' ? deliveryLocation : 'Your Location';
    %>

    <!-- ══════════ TOP NAVBAR ══════════ -->
    <header class="topbar">
      <div class="topbar-inner">
        <a href="/" class="logo">
          <span>🛒</span>
          <span class="logo-text">Ansu<em>Mart</em></span>
        </a>

        <div class="delivery-badge">
          <span>⚡</span>
          <div>
            <p class="del-title">Delivery in <strong>
                <%= _delText %>
              </strong></p>
            <p class="del-sub"><i class="fa-solid fa-location-dot"></i>
              <%= _delLoc %>
            </p>
          </div>
        </div>

        <div class="topbar-actions">
          <a href="/shop" class="tb-btn">🏪 Shop</a>
          <button class="tb-btn cart-btn" id="cartToggleBtn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="21" r="1" />
              <circle cx="20" cy="21" r="1" />
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
            </svg>
            My Cart
            <span class="cart-count" id="cartCount">0</span>
          </button>
          <% if(user){ %>

            <a href="/profile" class="login-btn">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>

              <%= user.firstName %>
            </a>

            <% } else { %>

              <a href="/login" class="login-btn">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>

                Login
              </a>

              <% } %>
        </div>
      </div>
    </header>

    <div class="page-wrap">

      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/shop">Shop</a>
        <span>›</span>
        <a href="/shop?cat=<%= encodeURIComponent(product.category) %>">
          <%= product.category %>
        </a>
        <span>›</span>
        <span class="bc-current">
          <%= product.title %>
        </span>
      </nav>

      <!-- ══════════ PRODUCT DETAIL ══════════ -->
      <section class="product-detail">

        <!-- Image Gallery -->
        <div class="gallery">
          <div class="gallery-main">
            <img id="mainImg"
              src="<%= product.images && product.images.length ? product.images[0] : (product.image || '') %>"
              alt="<%= product.title %>"
              onerror="this.src='https://images.pexels.com/photos/4397921/pexels-photo-4397921.jpeg?auto=compress&w=600'" />
            <span class="del-tag">⏱ <%= _delText.toUpperCase() %> DELIVERY</span>
          </div>

          <% if(product.images && product.images.length> 1){ %>
            <div class="gallery-thumbs">
              <% product.images.forEach(function(img, i){ %>
                <img class="thumb <%= i===0 ? 'active' : '' %>" src="<%= img %>"
                  alt="<%= product.title %> view <%= i+1 %>" data-src="<%= img %>"
                  onerror="this.src='https://images.pexels.com/photos/4397921/pexels-photo-4397921.jpeg?auto=compress&w=120'" />
                <% }); %>
            </div>
            <% } %>
        </div>

        <!-- Product Info -->
        <div class="prod-info">
          <span class="cat-pill">
            <%= product.category %>
          </span>
          <h1 class="prod-title">
            <%= product.title %>
          </h1>
          
          <% if (product.quantity > 0 && product.quantity < 5) { %>
            <div style="color: #ef4444; font-weight: 700; font-size: 14px; margin-bottom: 8px; margin-top: 4px;">🔥 Only few left</div>
          <% } %>

          <% if(product.description){ %>
            <p class="prod-desc">
              <%= product.description %>
            </p>
            <% } %>

              <div class="price-row">
                <span class="prod-price">₹<%= product.price %></span>
                <% if(product.mrp && product.mrp> product.price){ %>
                  <span class="prod-mrp">₹<%= product.mrp %></span>
                  <span class="prod-discount">
                    <%= Math.round((product.mrp - product.price)/product.mrp*100) %>% OFF
                  </span>
                  <% } %>
              </div>

              <div class="delivery-info-box">
                <div class="dib-row"><span>⚡</span>
                  <div><strong>Express Delivery</strong>
                    <p>Delivered in <%= _delText %>
                    </p>
                  </div>
                </div>
                <div class="dib-row"><span>🔄</span>
                  <div><strong>Easy Returns</strong>
                    <p>7-day hassle-free returns</p>
                  </div>
                </div>
                <div class="dib-row"><span>✅</span>
                  <div><strong>Quality Assured</strong>
                    <p>100% genuine products</p>
                  </div>
                </div>
              </div>

              <div class="action-row">
                <div class="qty-stepper" id="qtyStepper">
                  <button class="qs-dec" id="qsDec">−</button>
                  <span class="qs-num" id="qsNum">1</span>
                  <button class="qs-inc" id="qsInc">+</button>
                </div>
                <button class="add-cart-btn" id="addCartBtn" data-id="<%= product._id %>"
                  data-name="<%= product.title %>" data-price="<%= product.price %>"
                  data-img="<%= product.images && product.images.length ? product.images[0] : (product.image||'') %>">
                  🛒 Add to Cart
                </button>
                <button class="wish-toggle" id="wishToggle" data-id="<%= product._id %>">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                      d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                  </svg>
                </button>
              </div>

              <% if(product.tags && product.tags.length){ %>
                <div class="tags-row">
                  <% product.tags.forEach(function(t){ %>
                    <span class="tag-pill">#<%= t %></span>
                    <% }); %>
                </div>
                <% } %>
        </div>
      </section>

      <!-- ══════════ SUGGESTIONS ══════════ -->
      <section class="suggestions-section">
        <h2 class="sec-title">You May Also Like</h2>
        <div class="sug-grid" id="sugGrid">
          <% related.forEach(function(p){ %>
            <a href="/product/<%= p._id %>" class="sug-card">
              <div class="sug-img-wrap">
                <img src="<%= p.images && p.images.length ? p.images[0] : (p.image || '') %>" alt="<%= p.title %>"
                  onerror="this.src='https://images.pexels.com/photos/4397921/pexels-photo-4397921.jpeg?auto=compress&w=300'" />
              </div>
              <div class="sug-body">
                <p class="sug-name">
                  <%= p.title %>
                </p>
                <span class="sug-price">₹<%= p.price %></span>
              </div>
              <button class="sug-add"
                onclick="event.preventDefault(); quickAdd('<%= p._id %>','<%= p.title.replace(/'/g,'') %>',<%= p.price %>,'<%= p.images && p.images.length ? p.images[0] : (p.image||'') %>')">+
                ADD</button>
            </a>
            <% }); %>
        </div>
      </section>

    </div>

    <!-- CART DRAWER -->
    <aside class="cart-drawer" id="cartDrawer">
      <div class="cart-head">
        <div>
          <h3>My Cart</h3>
          <p class="cart-subhead" id="cartSubhead">0 items</p>
        </div>
        <button class="cart-close" id="cartClose">✕</button>
      </div>

      <div class="free-del-bar" id="freeDelBar">
        <div class="fdbar-track">
          <div class="fdbar-fill" id="fdbarFill" style="width:0%"></div>
        </div>
        <p id="fdbarMsg">Add ₹499 more for <strong>FREE delivery</strong></p>
      </div>

      <div class="cart-body" id="cartBody">
        <div class="cart-empty" id="cartEmpty">
          <span>🛒</span>
          <p>Your cart is empty</p>
          <small>Add items to start shopping</small>
        </div>
      </div>

      <div class="cart-foot hidden" id="cartFoot">
        <div class="bill-row"><span>Item total</span><span id="billItems">₹0</span></div>
        <div class="bill-row"><span>Delivery fee</span><span id="billDel">₹30</span></div>
        <div class="bill-row bill-total"><span>To Pay</span><span id="billTotal">₹30</span></div>
        <button class="checkout-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
          Proceed to Checkout
        </button>
      </div>
    </aside>
    <div class="cart-overlay hidden" id="cartOverlay"></div>

    <!-- Toast -->
    

<% if(typeof user !== 'undefined' && user) { %>
<!-- ═══════ BOTTOM NAV (MOBILE) ═══════ -->
<nav class="bottom-nav">
  <a href="/store" class="bnav-item ">
    <i class="fa-solid fa-house"></i>
    <span>Home</span>
  </a>
  <a href="/shop" class="bnav-item active">
    <i class="fa-solid fa-bag-shopping"></i>
    <span>Shop</span>
  </a>
  <a href="/cart" class="bnav-item ">
    <i class="fa-solid fa-cart-shopping"></i>
    <span>Cart</span>
  </a>
  <a href="/profile" class="bnav-item ">
    <i class="fa-solid fa-user"></i>
    <span>Profile</span>
  </a>
</nav>
<% } %>

<div class="toast" id="toast"></div>

    <script>
      window.__PRODUCT_ID__ = '<%= product._id %>';
    </script>
    <script src="/js/product.js"></script>
</body>

</html>